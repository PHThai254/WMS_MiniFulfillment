    "DefaultConnection": "Server=.;Database=WMS_MiniFulfillment;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "REPLACE_THIS_WITH_A_SECRET_KEY_AT_LEAST_32_CHARS_LONG",
